<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<include name="View_504V_Wall_H">
		<control type="group">
 			<include>OpenClose_Right</include>
			<left>0</left>
			<top>0</top>
			<width>100%</width>
			<height>100%</height>
			<visible>Control.IsVisible(504)</visible>
			<include>Visible_Right</include>
			<control type="panel" id="504">
				<left>30</left>
				<right>30</right>
				<top>140</top>
<!--				<width>1800</width> -->
				<height>850</height>
				<onleft>504</onleft>
				<onright>504</onright>
				<onup condition="Integer.IsGreater(Container.NumPages,1)">5198</onup>
				<onup condition="!Integer.IsGreater(Container.NumPages,1)">9000</onup>
				<ondown>504</ondown>
				<orientation>horizontal</orientation>
				<viewtype label="31201">icon</viewtype>
				<preloaditems>2</preloaditems>
				<pagecontrol>5198</pagecontrol>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<visible>Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes) | Container.Content(artists) | Container.Content(albums) | Container.Content(musicvideos) | Container.Content(addons) | Container.Content(images) | Container.Content(videos) | Container.Content(games) | Container.Content(favourites)</visible>
				<itemlayout height="401" width="335" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<top>0</top>
						<include>InfoWallMovieLayout</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="335" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="150,222">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="150,222">UnFocus</animation>
						<top>0</top>
						<include content="InfoWallMovieLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="350" width="335" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<top>10</top>
						<include content="InfoWallEpisodeLayout2">
							<param name="label" value="$INFO[ListItem.Label]" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="350" width="335" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="150,222">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="150,222">UnFocus</animation>
						<top>10</top>
						<include content="InfoWallEpisodeLayout2">
							<param name="focused" value="true" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="335" condition="Container.Content(images)">
					<control type="group">
						<left>25</left>
						<top>10</top>
						<include>InfoWallPictureLayout2</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="335" condition="Container.Content(images)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="150,222">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="150,222">UnFocus</animation>
						<left>25</left>
						<top>10</top>
						<include content="InfoWallPictureLayout2">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="335" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<left>25</left>
						<top>10</top>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultMusicSongs.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="335" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>25</left>
						<top>10</top>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="168,350">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="168,350">UnFocus</animation>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultMusicSongs.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="335" condition="Container.Content(addons)">
					<control type="group">
						<left>25</left>
						<top>10</top>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultAddon.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="335" condition="Container.Content(addons)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>25</left>
						<top>10</top>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="168,350">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="168,350">UnFocus</animation>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultAddon.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="335" condition="Container.Content(favourites)">
					<control type="group">
						<left>25</left>
						<top>10</top>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultFavourites.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="335" condition="Container.Content(favourites)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>25</left>
						<top>10</top>
						<animation effect="zoom" start="100" end="110" time="200" tween="sine" easing="inout" center="168,350">Focus</animation>
						<animation effect="zoom" start="110" end="100" time="200" tween="sine" easing="inout" center="168,350">UnFocus</animation>
						<include content="InfoWallMusicLayout2">
							<param name="fallback_image" value="DefaultFavourites.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
			</control>
		</control>
	</include>
</includes>
